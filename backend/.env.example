# ---- Target ad server ----
AD_SERVER_URL=http://localhost:8001
# Admin credentials for seeding via REST. Open registration only grants the
# "trafficker" role (which cannot create advertisers/campaigns), so seeding needs
# an admin account. Point these at an existing admin on your ad server.
AD_SERVER_EMAIL=dev@localhost.com
AD_SERVER_PASSWORD=admin123
# If the configured user does not exist, optionally self-register it (note: the
# server forces role=trafficker on open registration, so this only enables the
# subset of operations a trafficker is allowed to perform).
AUTO_REGISTER=true

# ---- Traffic generation ----
REQUESTS_PER_SECOND=50
CONCURRENCY=10
TOTAL_REQUESTS=500
DURATION_SECONDS=0
# Comma-separated subset of {vast, ortb}
SERVE_PROTOCOLS=vast

# ---- Impression / click ----
DEFAULT_IMPRESSION_RATE=0.9
DEFAULT_CTR=0.03
IMPRESSION_DELAY_MIN_MS=200
IMPRESSION_DELAY_MAX_MS=2500

# ---- User simulation ----
USER_POOL_SIZE=200
RETURNING_USER_RATIO=0.6

# ---- Tracking behaviour ----
# Rewrite embedded /track/* URLs to /api/track/* and to AD_SERVER_URL host so
# events record locally (each rewrite is reported as a finding).
TRACKING_PREFIX_FIX=true

# ---- Storage ----
SIM_DB_PATH=./sim.db

# ---- Traffic dimension pools ----
COUNTRIES=IN,US,UK,CA
DEVICES=mobile,desktop,tablet
BROWSERS=chrome,firefox,safari,edge
